# --- Brains ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_MODEL_QA=gemini-2.5-flash-lite   # cheap second-pass QA / classification

# --- Tool layer ---
COMPOSIO_API_KEY=     # Reddit/X/GitHub search, Google Sheets
GITHUB_TOKEN=         # free PAT (public_repo read) — enables GitHub org source + commit-email discovery

# --- Email layer (AgentMail: inboxes, send/receive, domains) ---
AGENTMAIL_API_KEY=    # console.agentmail.to -> API keys. Developer plan needed for custom domains.

# --- Product analytics ---
POSTHOG_API_KEY=
POSTHOG_PROJECT_ID=
POSTHOG_HOST=https://us.posthog.com

# --- Email verification (self-hosted Reacher, see services/reacher) ---
REACHER_URL=http://localhost:8080

# --- Discord (agents post via channel webhooks; no bot needed for posting) ---
# Channel settings -> Integrations -> Webhooks -> New Webhook -> copy URL
DISCORD_WEBHOOK_SIGNALS=
DISCORD_WEBHOOK_REPLIES=
DISCORD_WEBHOOK_NEW_SIGNUPS=
DISCORD_WEBHOOK_GTM_DAILY=
# Only needed for the /draft slash command (https://discord.com/developers/applications)
DISCORD_APP_ID=
DISCORD_PUBLIC_KEY=
DISCORD_BOT_TOKEN=      # used once by scripts/register-discord-commands.cjs

# --- Engine ---
DATABASE_PATH=./gtm.db
DRY_RUN=true          # live sending requires explicit flip to false
TZ=Asia/Kolkata
PORT=3000
